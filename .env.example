# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...
# Modello di default per chain di reasoning / report
ANTHROPIC_MODEL=claude-opus-4-7
# Modello veloce/economico per task ausiliari (chunking, classification)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Embeddings — usiamo Voyage (raccomandato da Anthropic) o OpenAI
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Inngest =====
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ===== Data sources =====
# RSS feed extra (comma-separated)
RSS_FEEDS_EXTRA=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
