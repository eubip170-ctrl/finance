# Supabase (server-only).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# OpenAI (LLM for studier + brain cluster labels).
OPENAI_API_KEY=sk-...
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_DEEP=gpt-4o

# Voyage AI (optional embeddings provider; falls back to OpenAI).
VOYAGE_API_KEY=

# MarketStack v2 — EOD provider for dashboard / focus / charts.
MARKETSTACK_API_KEY=

# Inngest (long-running steps).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# /api/seed bootstrap. Leave unset on a personal deploy to keep it open.
SEED_TOKEN=

# Daily market-cache refresh — used by .github/workflows/refresh-market.yml
# Generate something random: openssl rand -hex 32
# Then set it both here (Vercel env) and as a GitHub Actions repository
# secret named CRON_SECRET. Also add MARKET_REFRESH_URL with the full
# https://your-domain.vercel.app/api/cron/refresh-market URL.
CRON_SECRET=
