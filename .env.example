# ===== LLM (OpenAI) =====
OPENAI_API_KEY=sk-...
# Modello principale (reasoning, report, simulazione). Default economico:
OPENAI_MODEL=gpt-4o-mini
# Modello veloce/economico per task ausiliari (può coincidere col principale)
OPENAI_FAST_MODEL=gpt-4o-mini

# ===== Embeddings =====
# Default: openai → text-embedding-3-small forzato a 1024 dims (compatibile col schema Supabase).
EMBEDDINGS_PROVIDER=openai
# Alternativa, se vuoi provare Voyage (200M token gratis sul tier free):
# EMBEDDINGS_PROVIDER=voyage
# VOYAGE_API_KEY=

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Inngest =====
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ===== Data sources =====
# RSS feed extra (comma-separated URL)
RSS_FEEDS_EXTRA=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
